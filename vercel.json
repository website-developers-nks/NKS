{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/company{/}?", "destination": "/about.html", "permanent": true },
    { "source": "/culture-career{/}?", "destination": "/culture.html", "permanent": true },
    { "source": "/campus-recruitment{/}?", "destination": "/culture.html", "permanent": true },
    { "source": "/contact{/}?", "destination": "/contact.html", "permanent": true },
    { "source": "/open-positions{/}?", "destination": "/open-positions.html", "permanent": true },
    { "source": "/privacy-policy{/}?", "destination": "/privacy-policy.html", "permanent": true },
    { "source": "/credits{/}?", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|robots\\.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
